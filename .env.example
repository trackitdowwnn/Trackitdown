# WHAT:  Template for the local .env file — copy to `.env` and fill in.
# WHY:   Makes required config self-documenting. The real .env is
#        gitignored and must NEVER be committed.
# LINKS: docs/SECURITY_AND_TRUST.md (secrets rules).
#
# IMPORTANT: Only PUBLIC values belong in this file. EXPO_PUBLIC_* vars
# are bundled into the app and visible to anyone. Server secrets
# (Stripe secret key, DVLA API key, Supabase service-role key) live in
# Supabase Edge Function secrets — set with:
#   npx supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# They must never appear here, in app code, or in the repo.

# Supabase (dev project) — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe — test mode publishable key only (pk_test_...)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Maps SDK keys — read by app.config.ts at build time (NOT bundled as
# EXPO_PUBLIC; embedded in the native binary by the react-native-maps plugin).
# Needed for ANY build that shows a map: Expo Go can NOT render Google Maps on
# Android (its bundled key is no longer authorized — expo/expo#39301), so use a
# dev build (`npx expo run:android`). Create in Google Cloud Console, enable
# the matching SDK per key, and restrict each key to the app's package name /
# bundle id (+ the debug keystore SHA-1 for local Android dev builds):
#   - Maps SDK for Android -> GOOGLE_MAPS_ANDROID_API_KEY
#   - Maps SDK for iOS      -> GOOGLE_MAPS_IOS_API_KEY
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Google Sign-In (features/auth) — OAuth client IDs from Google Cloud Console
# (APIs & Services -> Credentials). These are PUBLIC client ids, not secrets.
#   - Web client id     -> passed to GoogleSignin.configure({ webClientId }); it
#     is ALSO the Client ID you register in the Supabase Google provider, so the
#     idToken audience matches (signInWithIdToken).
#   - iOS client id     -> GoogleSignin.configure({ iosClientId }).
#   - iOS URL scheme    -> the REVERSED iOS client id
#     (com.googleusercontent.apps.<id>); read by app.config.ts at build time.
# Add the iOS + Android client ids to the Supabase provider's "Authorized Client
# IDs" list too. Social sign-in stays inert until these are set + a new dev
# build is made — see src/features/auth/README.md.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
GOOGLE_IOS_URL_SCHEME=
